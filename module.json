    "relationships": {
        "systems": [
            {
                "id": "daggerheart",
                "type": "system",
                "compatibility": {
                    "minimum": "1.8.0"
                }
            }
        ]
    },
    "packFolders": [
        {
            "name": "Daggerheart COD",
            "sorting": "m",
            "color": "#08718c",
            "packs": [
                "colossal-adversaries",
                "colossal-weapons",
                "colossal-loot",
                "colossal-segments",
                "colossal-generator-tables"
            ]
        }
    ],
    "esmodules": [

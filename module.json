{
    "id": "fb-cod",
    "title": "Daggerheart: COD",
    "description": "Daggerheart extension adding Colossus of the Drylands adversaries and related content.",
    "version": "1.3.2",
    "compatibility": {
        "minimum": "13",
        "verified": "13.351"
    },
    "url": "https://github.com/juvinious/fb-cod",
    "manifest": "https://github.com/juvinious/fb-cod/releases/latest/download/module.json",

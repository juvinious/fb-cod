<section class='tab {{tabs.settings.cssClass}} {{tabs.settings.id}}' data-tab='{{tabs.settings.id}}'
    data-group='{{tabs.settings.group}}'>
    {{!-- === Core Combat Stats === --}}
    <fieldset class="two-columns">
        <legend>Combat Stats</legend>

        <span>Segment Type</span>
        {{formInput document.system.schema.fields.segmentType value=document.system.segmentType
        choices=segmentTypeChoices localize=false}}

        <span>Difficulty</span>
        {{formInput document.system.schema.fields.difficulty value=document.system.difficulty}}

        <span>Adjacent Segments</span>
        <div class="adjacent-segments-list">
            {{#each neighborCandidates}}
            <label class="checkbox-pill">
                <input type="checkbox" name="system.adjacentSegments" value="{{this.id}}" {{checked this.checked}}>
                <span>{{this.name}}</span>
            </label>
            {{else}}
            <p class="notes">No other segments found on this Colossus.</p>
            {{/each}}
        </div>
    </fieldset>

    {{!-- === Defeat Conditions === --}}
    <fieldset>
        <legend>Defeat Conditions</legend>

        <div class="form-group">
            {{formInput document.system.schema.fields.fatal value=document.system.fatal}}
            <span>Fatal — Destroying this segment defeats the Colossus</span>
        </div>

        <div class="form-group">
            <span>Chain Group</span>
            {{formInput document.system.schema.fields.chainGroup value=document.system.chainGroup
            choices=chainGroupChoices localize=false}}
        </div>
    </fieldset>

    {{!-- === Current Status === --}}
    {{!--
    <fieldset>
        <legend>Status</legend>

        <div class="form-group">
            {{formInput document.system.schema.fields.broken value=document.system.broken}}
            <span>Broken</span>
        </div>

        <div class="form-group">
            {{formInput document.system.schema.fields.collapsed value=document.system.collapsed}}
            <span>Collapsed</span>
        </div>

        <div class="form-group">
            {{formInput document.system.schema.fields.destroyed value=document.system.destroyed}}
            <span>Destroyed</span>
        </div>
    </fieldset>--}}

</section>
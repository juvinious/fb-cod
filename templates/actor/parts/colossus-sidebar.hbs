<aside class="adversary-sidebar-sheet">
    <div class="portrait {{#if isDefeated}}death-roll{{/if}}">
        <img src="{{source.img}}" alt="{{source.name}}" data-action='editImage' data-edit="img">
        {{#if isDefeated}}
        <a class="death-roll-btn"><i class="fa-solid fa-skull death-save"></i></a>
        {{/if}}
    </div>

    <div class="info-section {{#if useResourcePips}}pip-display{{/if}}">
        <div class="resources-section">
            {{> "systems/daggerheart/templates/sheets/global/partials/resource-bar.hbs" resource=resources.stress
            label="DAGGERHEART.GENERAL.stress" key="system.resources.stress.value" action="toggleStress" }}
        </div>
        <div class="status-section">
            <div class="status-number">
                <div class='status-value armor-slots'>
                    {{#if source.system.difficulty}}
                    <p>{{source.system.difficulty}}</p>
                    {{else}}
                    <p>-</p>
                    {{/if}}
                </div>
                <div class="status-label">
                    <h4>{{localize "DAGGERHEART.GENERAL.difficulty"}}</h4>
                </div>
            </div>
            {{!-- Colossus shows Damage Thresholds in the stat row --}}
            <div class="status-number">
                <div class='status-value armor-slots'>
                    {{#if source.system.criticalThreshold}}
                    <p>{{source.system.criticalThreshold}}+</p>
                    {{else}}
                    <p>-</p>
                    {{/if}}
                </div>
                <div class="status-label">
                    <h4>{{localize "DAGGERHEART.GENERAL.criticalShort"}}</h4>
                </div>
            </div>
        </div>
        <div class="status-section">
            <div class="threshold-section">
                <h4 class="threshold-label">{{localize "DAGGERHEART.GENERAL.DamageThresholds.minor"}}</h4>
                <h4 class="threshold-value">{{document.system.damageThresholds.major}}</h4>
                <h4 class="threshold-label">{{localize "DAGGERHEART.GENERAL.DamageThresholds.major"}}</h4>
                <h4 class="threshold-value">{{document.system.damageThresholds.severe}}</h4>
                <h4 class="threshold-label">{{localize "DAGGERHEART.GENERAL.DamageThresholds.severe"}}</h4>
            </div>
        </div>
    </div>

    <div class="shortcut-items-section">
        {{!-- === Segment Attacks Section === --}}
        <div class="attack-section">
            <div class="title">
                <side-line-div class="invert"></side-line-div>
                <h3>{{localize "DAGGERHEART.GENERAL.attack"}}</h3>
                <side-line-div></side-line-div>
            </div>
            <ul class="items-sidebar-list">
                {{#each segmentAttacks as |action|}}
                {{!-- Segment name label --}}
                <li class="segment-atk-label" style="font-size:0.75em; opacity:0.6; padding:2px 8px 0; margin-top:4px;">
                    {{action._segmentName}}
                </li>
                {{!--
                Custom attack card: portrait click uses rollSegmentAttack with data-segment-uuid + data-action-id
                so we look up the action directly (bypassing fromUuid→Item→ActionSelectionDialog confusion).
                --}}
                <li class="inventory-item inventory-item-compact" data-action-id="{{action.id}}" data-item-uuid="{{action.uuid}}" data-type="{{action.type}}"
                    data-segment-uuid="{{action._segmentUuid}}">
                    <div class="img-portait" data-action="rollSegmentAttack" data-action-id="{{action.id}}"
                        data-segment-uuid="{{action._segmentUuid}}" data-tooltip="Roll {{action.name}}">
                        <img src="{{action.img}}" class="item-img" />
                        <img class="roll-img d20" src="systems/daggerheart/assets/icons/dice/default/d20.svg" alt="d20">
                    </div>
                    {{!-- Use #with to set action as context, then call this._getLabels (same as inventory-item-compact)
                    --}}
                    {{#with action}}
                    <span class="item-name">{{this.name}}</span>
                    <div class="item-labels">
                        <div class="label">
                            {{#each this._getLabels as |label|}}
                            {{#if label.value}}{{label.value}}{{else}}{{label}}{{/if}}
                            {{#each label.icons as |icon|}}<i class="fa-solid {{icon}}"></i>{{/each}}
                            {{#if (not @last)}}<span>-</span>{{/if}}
                            {{/each}}
                        </div>
                    </div>
                    {{/with}}

                    <div class="controls">
                        <a data-action="toSegmentChat" data-action-id="{{action.id}}"
                            data-segment-uuid="{{action._segmentUuid}}"
                            data-tooltip="DAGGERHEART.UI.Tooltip.sendToChat"><i
                                class="fa-regular fa-fw fa-message"></i></a>
                        <a data-action="editDoc" data-item-uuid="{{action._segmentUuid}}" data-tooltip="Edit Segment"><i
                                class="fa-solid fa-fw fa-ellipsis-vertical"></i></a>
                    </div>
                </li>
                {{else}}
                <li style="text-align:center; opacity:0.5; padding:8px; font-size:0.85em;">
                    No segment attacks defined yet.
                </li>
                {{/each}}

            </ul>
        </div>

        {{!-- === Segment Reactions Section === --}}
        <div class="attack-section">
            <div class="title">
                <side-line-div class="invert"></side-line-div>
                <h3>{{localize "DAGGERHEART.CONFIG.FeatureForm.reaction"}}</h3>
                <side-line-div></side-line-div>
            </div>
            <ul class="items-sidebar-list">
                {{#each segmentReactions as |action|}}
                {{!-- Segment name label --}}
                <li class="segment-atk-label" style="font-size:0.75em; opacity:0.6; padding:2px 8px 0; margin-top:4px;">
                    {{action._segmentName}}
                </li>
                {{!--
                Custom attack card: portrait click uses rollSegmentAttack with data-segment-uuid + data-action-id
                so we look up the action directly (bypassing fromUuid→Item→ActionSelectionDialog confusion).
                --}}
                <li class="inventory-item inventory-item-compact" data-action-id="{{action.id}}" data-item-uuid="{{action.uuid}}" data-type="{{action.type}}"
                    data-segment-uuid="{{action._segmentUuid}}">
                    <div class="img-portait" data-action="rollSegmentAttack" data-action-id="{{action.id}}"
                        data-segment-uuid="{{action._segmentUuid}}" data-tooltip="Roll {{action.name}}">
                        <img src="{{action.img}}" class="item-img" />
                        <img class="roll-img d20" src="systems/daggerheart/assets/icons/dice/default/d20.svg" alt="d20">
                    </div>
                    {{!-- Use #with to set action as context, then call this._getLabels (same as inventory-item-compact)
                    --}}
                    {{#with action}}
                    <span class="item-name">{{this.name}}</span>
                    <div class="item-labels">
                        <div class="label">
                            {{#each this._getLabels as |label|}}
                            {{#if label.value}}{{label.value}}{{else}}{{label}}{{/if}}
                            {{#each label.icons as |icon|}}<i class="fa-solid {{icon}}"></i>{{/each}}
                            {{#if (not @last)}}<span>-</span>{{/if}}
                            {{/each}}
                        </div>
                    </div>
                    {{/with}}

                    <div class="controls">
                        <a data-action="toSegmentChat" data-action-id="{{action.id}}"
                            data-segment-uuid="{{action._segmentUuid}}"
                            data-tooltip="DAGGERHEART.UI.Tooltip.sendToChat"><i
                                class="fa-regular fa-fw fa-message"></i></a>
                        <a data-action="editDoc" data-item-uuid="{{action._segmentUuid}}" data-tooltip="Edit Segment"><i
                                class="fa-solid fa-fw fa-ellipsis-vertical"></i></a>
                    </div>
                </li>
                {{else}}
                <li style="text-align:center; opacity:0.5; padding:8px; font-size:0.85em;">
                    No segment reactions defined yet.
                </li>
                {{/each}}

            </ul>
        </div>

        {{!-- === Experiences Section === --}}
        <div class="experience-section">
            <div class="title">
                <side-line-div class="invert"></side-line-div>
                <h3>{{localize "DAGGERHEART.GENERAL.experience.plural"}}</h3>
                <side-line-div></side-line-div>
            </div>
            <div class="experience-list">
                {{#each source.system.experiences as |experience id|}}
                <div class="experience-row" data-tooltip-text="{{experience.description}}">
                    <span class="experience-value">
                        +{{experience.value}}
                    </span>
                    <span class="experience-name">{{experience.name}}</span>
                    <div class="controls">
                        <a data-action="sendExpToChat" data-id="{{id}}">
                            <i class="fa-regular fa-message"></i>
                        </a>
                    </div>
                </div>
                {{/each}}
            </div>
        </div>

        <line-div></line-div>
        <div class="reaction-section">
            <button type="button" data-action="reactionRoll">{{localize "DAGGERHEART.GENERAL.Roll.reaction"}}</button>
        </div>
    </div>
</aside>
<section class="tab {{tabs.segments.cssClass}} segments" data-tab="segments" data-group="primary">
    {{!-- Condition Immunities Section --}}
    <div class="colossus-conditions"
        style="display:flex; justify-content:space-around; background:rgba(0,0,0,0.2); border:1px solid #f5b85a; border-radius:5px; padding:10px; margin-bottom:15px;">
        <h4
            style="margin:0; font-family:'Modesto Condensed', serif; font-size:1.2rem; color:#f5b85a; align-self:center;">
            Condition Immunities:</h4>
        <div class="condition-toggle {{#if conditionImmunities.hidden}}active{{/if}}" data-action="toggleCondition"
            data-condition="hidden"
            style="cursor:pointer; opacity:{{#if conditionImmunities.hidden}}1{{else}}0.5{{/if}};">
            <i class="fas fa-ghost"></i> Hidden
        </div>
        <div class="condition-toggle {{#if conditionImmunities.restrained}}active{{/if}}" data-action="toggleCondition"
            data-condition="restrained"
            style="cursor:pointer; opacity:{{#if conditionImmunities.restrained}}1{{else}}0.5{{/if}};">
            <i class="fas fa-link"></i> Restrained
        </div>
        <div class="condition-toggle {{#if conditionImmunities.vulnerable}}active{{/if}}" data-action="toggleCondition"
            data-condition="vulnerable"
            style="cursor:pointer; opacity:{{#if conditionImmunities.vulnerable}}1{{else}}0.5{{/if}};">
            <i class="fas fa-skull"></i> Vulnerable
        </div>
    </div>

    <div class="segments-header"
        style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px; border-bottom:1px solid rgba(255,255,255,0.1); padding-bottom:5px;">
        <h3 style="margin:0; font-family:'Modesto Condensed', serif; color:#f5b85a;">{{localize "Colossal Segments"}}
        </h3>
        <a data-action="addSegment" data-tooltip="Add Segment">
            <i class="fa-solid fa-plus icon-button"></i>
        </a>
    </div>

    <div class="segments-list-container scrollable">
        {{#if hasSegments}}
        {{#each segmentGroups as |group|}}
        <h4 class="chain-header"
            style="margin-top:15px; margin-bottom:5px; margin-left:10px; font-family:'Modesto Condensed', serif; color:#cda36f; text-shadow: 1px 1px 2px black;">
            {{group.name}} {{#if group.isChainDefeated}}<span
                style="color:#d55; font-size: 0.8em; vertical-align: middle;">[Chain Defeated]</span>{{/if}}
        </h4>
        <ul class="items-list segments-list">
            {{#each group.segments as |segment|}}
                <li class="inventory-item segment-item {{#if segment.system.destroyed}}destroyed{{/if}} {{#if segment.system.isBroken}}broken{{/if}} {{#if segment.system.isCollapsed}}collapsed{{/if}}"
                data-item-id="{{segment.id}}" data-item-uuid="{{segment.uuid}}" data-type="fb-cod.colossal-segment">
                <div class="inventory-item-header padded">
                    {{!-- Image/Portrait opens the native FeatureSheet --}}
                    <div class="img-portait" data-action="editDoc" data-item-uuid="{{segment.uuid}}"
                        data-tooltip="Edit Segment" style="cursor: pointer;">
                        <img src="{{segment.img}}" class="item-img" />
                        <img class="roll-img d20" src="systems/daggerheart/assets/icons/dice/default/d20.svg" alt="d20">
                    </div>

                    {{!-- Name & Tags --}}
                    <div class="item-label" data-action="editDoc" data-item-uuid="{{segment.uuid}}"
                        style="cursor: pointer;" data-tooltip="Edit Segment">
                        <span class="item-name">{{segment.name}} <span
                                style="opacity:0.6; font-size:0.8em;">({{segment.system.segmentType}})</span></span>
                        <div class="item-tags">
                            {{#each segment.computedTags as |tag|}}
                            <div class="tag">{{tag}}</div>
                            {{/each}}
                        </div>
                    </div>

                    {{!-- Stats/Resources (Difficulty, HP, Tokens) --}}
                    <div class="item-resource"
                        style="display:flex; align-items:center; gap:12px; margin-right:15px; flex-wrap:nowrap; min-width:300px; justify-content: flex-end;">
                        
                        {{!-- Difficulty --}}
                        <div class="stat" title="Difficulty"><i class="fas fa-shield-alt"></i>
                            {{segment.system.difficulty}}
                        </div>

                        {{!-- Segment HP Control (Pill Style) --}}
                        <div class="stat segment-hp-control" title="HP">
                            <i class="fas fa-heart" style="color:#d55; margin-right:4px;"></i>
                            <a data-action="adjustSegmentHP" data-item-id="{{segment.id}}" data-adjustment="-1"
                                title="-1 HP">
                                <i class="fas fa-minus"></i>
                            </a>
                            <span class="token-value">{{segment.system.resource.value}} / {{segment.system.resource.max}}</span>
                            <a data-action="adjustSegmentHP" data-item-id="{{segment.id}}" data-adjustment="1"
                                title="+1 HP">
                                <i class="fas fa-plus"></i>
                            </a>
                        </div>
                    </div>

                    {{!-- Controls (Binary Toggles) --}}
                    <div class="controls" style="flex: 0 0 100px;">
                        {{!-- Broken Toggle --}}
                        <a class="toggle-broken {{#if segment.system.isBroken}}active{{/if}}"
                            data-action="toggleSegmentBroken" data-item-id="{{segment.id}}"
                            data-tooltip="Toggle Broken State">
                            <i class="fa-solid fa-hammer"></i>
                        </a>

                        {{!-- Collapsed Toggle --}}
                        <a class="toggle-collapsed {{#if segment.system.isCollapsed}}active{{/if}}"
                            data-action="toggleSegmentCollapsed" data-item-id="{{segment.id}}"
                            data-tooltip="Toggle Collapsed State">
                            <i class="fa-solid fa-chevron-down"></i>
                        </a>

                        {{!-- Destroyed Toggle --}}
                        <a class="toggle-destroyed {{#if segment.system.destroyed}}active{{/if}}"
                            data-action="toggleSegmentDestroyed" data-item-id="{{segment.id}}"
                            data-tooltip="{{#if segment.system.destroyed}}Restore Segment{{else}}Destroy Segment{{/if}}">
                            <i class="fa-solid fa-skull"></i>
                        </a>
                        
                        {{!-- Edit --}}
                        <a data-action="editDoc" data-item-uuid="{{segment.uuid}}" data-tooltip="Edit Segment">
                            <i class="fa-solid fa-edit"></i>
                        </a>
                        
                        {{!-- Delete --}}
                        <a data-action="deleteDoc" data-item-uuid="{{segment.uuid}}" data-tooltip="Delete Segment">
                            <i class="fas fa-trash"></i>
                        </a>
                    </div>
                </div>

                {{!-- If valid attack action exists on segment, render a compact attack block just like weapons --}}
                {{#if segment.system.hasAttack}}
                <div class="item-buttons segment-attacks">
                    {{#each segment.system.actions as |action|}}
                    {{#if (eq action.type "attack")}}
                    <div class="action-block"
                        style="display:block; width:100%; border-top:1px solid rgba(255,255,255,0.1); padding:4px 0;">
                        <button type="button" class="roll-action-btn" data-action="rollSegmentAttack"
                            data-segment-uuid="{{segment.uuid}}" data-action-id="{{action.id}}"
                            data-tooltip="Roll Attack">
                            <i class="fa-solid fa-dice-d20" style="margin-right:5px;"></i> {{action.name}}
                        </button>
                        <a data-action="toSegmentChat" data-segment-uuid="{{segment.uuid}}"
                            data-action-id="{{action.id}}" data-tooltip="To Chat" style="margin-left:8px; opacity:0.6;">
                            <i class="fa-regular fa-message"></i>
                        </a>
                    </div>
                    {{/if}}
                    {{/each}}
                </div>
                {{/if}}
            </li>
            {{/each}}
        </ul>
        {{/each}}
        {{else}}
        <div style="text-align:center; opacity:0.7; padding:20px;">No segments added yet. Press the + button to
            begin.</div>
        {{/if}}
    </div>
</section>